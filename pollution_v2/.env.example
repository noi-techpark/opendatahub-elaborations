# ── Open Data Hub ─────────────────────────────────────────────────────────────
ODH_AUTHENTICATION_URL=https://auth.opendatahub.testingmachine.eu/auth/
ODH_BASE_READER_URL=https://mobility.api.opendatahub.testingmachine.eu
ODH_BASE_WRITER_URL=https://mobility.share.opendatahub.testingmachine.eu
ODH_CLIENT_ID=odh-a22-dataprocessor
ODH_CLIENT_SECRET=******************************
ODH_GRANT_TYPE=client_credentials
ODH_PAGINATION_SIZE=10000
ODH_MAX_POST_BATCH_SIZE=10000
ODH_STATIONS_FILTER_ORIGIN=A22
ODH_MINIMUM_STARTING_DATE=2023-01-01

# username/password only needed when ODH_GRANT_TYPE=password
ODH_USERNAME=
ODH_PASSWORD=

# ── Computation batch sizes ────────────────────────────────────────────────────
ODH_COMPUTATION_BATCH_SIZE_POLL_ELABORATION=30
ODH_COMPUTATION_BATCH_SIZE_VALIDATION=1
ODH_COMPUTATION_BATCH_SIZE_POLL_DISPERSAL=30

# ── Checkpoint cache ───────────────────────────────────────────────────────────
# SQLite db file for computation checkpoints. Path is relative to /app inside the
# container; docker-compose mounts ./data → /app/data.
# To reset all checkpoints: rm -f ./data/checkpoint_cache.db
# Set to empty string to disable caching entirely.
COMPUTATION_CHECKPOINT_CACHE_PATH=data/checkpoint_cache.db

# ── Provenance ─────────────────────────────────────────────────────────────────
PROVENANCE_LINEAGE=u-hopper
PROVENANCE_NAME=a22-pollutant-elaboration
PROVENANCE_VERSION=0.1.0
# PROVENANCE_ID=   # set if the provenance record already exists in ODH

# ── Config files (paths relative to /app inside the container) ─────────────────
VALIDATOR_CONFIG_FILE=config/validator.yaml
ROAD_WEATHER_CONFIG_FILE=config/road_weather.yaml

# ── Road weather ───────────────────────────────────────────────────────────────
METRO_WS_PREDICTION_ENDPOINT=http://metro:80/predict/?station_code=
ROAD_WEATHER_MINUTES_BETWEEN_FORECASTS=60
ROAD_WEATHER_NUM_FORECASTS=45

# ── Pollution dispersal ────────────────────────────────────────────────────────
POLLUTION_DISPERSAL_STARTING_DATE=2020-12-01 02:00
POLLUTION_DISPERSAL_PREDICTION_ENDPOINT=http://rline:80/process/?dt=
POLLUTION_DISPERSAL_STATION_MAPPING_ENDPOINT=http://rline:80/get_capabilities/
POLLUTION_DISPERSAL_COMPUTATION_HOURS_SPAN=1

# ── Cron schedules (used by docker-compose; ignored by k8s CronJob) ────────────
VALIDATOR_CRON_SCHEDULE=0 2 * * *
POLLUTION_COMPUTER_CRON_SCHEDULE=0 4 * * *
ROAD_WEATHER_CRON_SCHEDULE=0 */3 * * *
POLLUTION_DISPERSAL_CRON_SCHEDULE=0 * * * *

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_LEVEL_LIBS=WARNING

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# SENTRY_DSN=https://...
SENTRY_SAMPLE_RATE=1.0

# ── Misc ──────────────────────────────────────────────────────────────────────
DATATYPE_PREFIX=
DEFAULT_TIMEZONE=Europe/Rome
